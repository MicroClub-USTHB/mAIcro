# ─────────────────────────────────────────────────
# mAIcro — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────

# ── LLM Provider ────────────────────────────────
LLM_PROVIDER=google
GEMINI_API_KEY=            # https://aistudio.google.com/app/apikey
MODEL_NAME=                # Optional override for the primary provider model


# ── Secondary LLM Provider (Fallback) ───────────
# Used when the primary provider is rate-limited.
# NOTE: If you set SECONDARY_LLM_PROVIDER=google, you should provide a different Gemini key/project below; otherwise both providers share the same quota.
SECONDARY_LLM_PROVIDER=google    # google | openai | ollama
SECONDARY_GEMINI_API_KEY=  # Different Gemini key/project if using google fallback
SECONDARY_MODEL_NAME=      # Optional override for the secondary model


# ── Discord ─────────────────────────────────────
# Create a bot at https://discord.com/developers/applications
# Enable MESSAGE CONTENT intent, then invite the bot to your server
# with "Read Message History" + "View Channels" permissions.
DISCORD_BOT_TOKEN=         # Bot → Token → Copy
DISCORD_CHANNEL_IDS=       # Comma-separated channel IDs to ingest, e.g. 123456789,987654321

# ── Qdrant (Vector Database) ────────────────────
# Sign up for the free 1 GB tier at https://cloud.qdrant.io
# Create a cluster → copy the URL and API key below.
QDRANT_URL=                # e.g. https://abc123-xyz.us-east4-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=            # Cluster → API Keys → Create

# ── Organization (optional) ─────────────────────
# Customize the AI personality for your org.
# ORG_NAME=MyOrganization
# ORG_DESCRIPTION=A brief description of your organization
# COLLECTION_NAME=my_org_knowledge
